  <!-- Mod Dependencies -->
  <ItemGroup>
    <PackageReference Include="Evaisa.LethalLib" Version="1.*" />
    
    <Reference Include="LethalConfig" HintPath="$(BepInExPluginsFolder)\AinaVT-LethalConfig\LethalConfig\LethalConfig.dll" />
  </ItemGroup>
  
  <!-- Settings -->
  <PropertyGroup>
    <Game>lethal-company</Game>
    <ThunderstoreTeamName>Zehs</ThunderstoreTeamName>
    <AssetBundleFileName>whiteboard_assets</AssetBundleFileName>
    <AssetBundleFolder>D:\LethalCompanyUnityProjects\LethalCompanyV81\Assets\LethalCompany\Mods\AssetBundles</AssetBundleFolder>
    
    <GaleProfileName>Mod Development Mini</GaleProfileName>
    <GaleProfileName2>NONE</GaleProfileName2>
    
    <GaleDataFolder>$(AppData)\com.kesomannen.gale</GaleDataFolder>
  </PropertyGroup>

  <PropertyGroup>
    <AssetBundleFilePath>$(AssetBundleFolder)\$(AssetBundleFileName)</AssetBundleFilePath>

    <GaleProfilesFolder>$(GaleDataFolder)\$(Game)\profiles</GaleProfilesFolder>

    <BepInExPluginsFolder>$(GaleProfilesFolder)\$(GaleProfileName)\BepInEx\plugins</BepInExPluginsFolder>
    <BepInExPluginsFolder2>$(GaleProfilesFolder)\$(GaleProfileName2)\BepInEx\plugins</BepInExPluginsFolder2>

    <PluginFolder>$(BepInExPluginsFolder)\$(ThunderstoreTeamName)-$(MSBuildProjectName)</PluginFolder>
    <PluginFolder2>$(BepInExPluginsFolder2)\$(ThunderstoreTeamName)-$(MSBuildProjectName)</PluginFolder2>
  </PropertyGroup>
  
  <!-- NetcodePatch -->
  <Target Name="NetcodePatch" AfterTargets="PostBuildEvent">
    <Message Text="Running NetcodePatch v73+" Importance="high" />
    <Exec Command="netcode-patch -uv 2022.3.62 -nv 1.12.2 -tv 1.0.0 &quot;$(TargetPath)&quot; @(ReferencePathWithRefAssemblies->'&quot;%(Identity)&quot;', ' ')" />
  </Target>
  
  <!-- Copy files to Gale plugin folder -->
  <Target Name="CopyToGalePluginFolder" AfterTargets="NetcodePatch">
    <Message Text="Copying to Gale plugin folders" Importance="high" />
    
    <!-- PluginFolder -->
    <Copy Condition="Exists('$(BepInExPluginsFolder)')" SourceFiles="$(TargetPath)" DestinationFolder="$(PluginFolder)" OverwriteReadOnlyFiles="true" SkipUnchangedFiles="true" />
    <Copy Condition="Exists('$(BepInExPluginsFolder)') And Exists('$(TargetDir)\$(AssetBundleFileName)')" SourceFiles="$(TargetDir)\$(AssetBundleFileName)" DestinationFolder="$(PluginFolder)" OverwriteReadOnlyFiles="true" SkipUnchangedFiles="true" />
    
    <!-- PluginFolder2 -->
    <Copy Condition="Exists('$(BepInExPluginsFolder2)')" SourceFiles="$(TargetPath)" DestinationFolder="$(PluginFolder2)" OverwriteReadOnlyFiles="true" SkipUnchangedFiles="true" />
    <Copy Condition="Exists('$(BepInExPluginsFolder2)') And Exists('$(TargetDir)\$(AssetBundleFileName)')" SourceFiles="$(TargetDir)\$(AssetBundleFileName)" DestinationFolder="$(PluginFolder2)" OverwriteReadOnlyFiles="true" SkipUnchangedFiles="true" />
  </Target>
  
  <!-- Call with `dotnet build -target:PackThunderstore` -->
  <Target Name="PackThunderstore">
    <Exec Command="dotnet tool restore" />
    <Exec Command="dotnet tcli build --config-path &quot;$(ProjectDir)Thunderstore\thunderstore.toml&quot; --package-version $(Version)" />

    <ItemGroup>
      <ThunderstorePackage Include="$(ProjectDir)Thunderstore\Packages\*-$(Version).zip" />
    </ItemGroup>
    <Move SourceFiles="@(ThunderstorePackage)" DestinationFolder="$(USERPROFILE)\Downloads\Thunderstore Builds" />
  </Target>
</Project>